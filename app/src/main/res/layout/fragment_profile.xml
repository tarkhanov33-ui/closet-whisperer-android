<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="Profile"
            android:textColor="@color/ink_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profileSubtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Update your account details."
            android:textColor="@color/ink_muted"
            android:textSize="14sp" />

        <!-- Sliding tab selector (TabLayout) -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/profileTabLayout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/rounded_card"
            android:backgroundTint="@color/border_subtle"
            app:tabGravity="fill"
            app:tabIndicator="@drawable/rounded_card"
            app:tabIndicatorColor="@color/white"
            app:tabIndicatorGravity="stretch"
            app:tabMaxWidth="0dp"
            app:tabMode="fixed"
            app:tabRippleColor="@android:color/transparent"
            app:tabSelectedTextColor="@color/ink_primary"
            app:tabTextColor="@color/ink_muted">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal info" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Style &amp; body" />
        </com.google.android.material.tabs.TabLayout>

        <!-- Container to toggle -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <!-- Personal Info Form -->
            <LinearLayout
                android:id="@+id/personalInfoForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Full Name -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Full name"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="@color/border_strong"
                    app:hintTextColor="@color/ink_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileFullName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:text="Shani"
                        android:textColor="@color/ink_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Username -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Username"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="@color/border_strong"
                    app:hintTextColor="@color/ink_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:text="shani"
                        android:textColor="@color/ink_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Email"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="@color/border_strong"
                    app:hintTextColor="@color/ink_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:text="demo@closetwhisperer.app"
                        android:textColor="@color/ink_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Date of Birth -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Date of birth"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxStrokeColor="@color/border_strong"
                    app:hintTextColor="@color/ink_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileDob"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="date"
                        android:textColor="@color/ink_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/profileSavePersonalBtn"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:backgroundTint="@color/brand_accent"
                        android:text="Save personal info"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:cornerRadius="8dp" />

                    <Button
                        android:id="@+id/profileResetPersonalBtn"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:text="Reset"
                        android:textColor="@color/ink_primary"
                        app:cornerRadius="8dp"
                        app:strokeColor="@color/border_strong" />
                </LinearLayout>
            </LinearLayout>

            <!-- Style & Body Form -->
            <LinearLayout
                android:id="@+id/styleBodyForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Visual Persona Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_card"
                    android:backgroundTint="@color/white"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/profilePersonaImage"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/rounded_card"
                        android:backgroundTint="@color/cream_200"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/brand_accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="serif"
                        android:text="Your visual persona"
                        android:textColor="@color/ink_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Upload a photo so we can preview outfits on your body shape."
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/profileUploadPhotoBtn"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Upload persona photo"
                        android:textColor="@color/ink_primary"
                        app:strokeColor="@color/border_strong" />
                </LinearLayout>

                <!-- Attributes grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <!-- Height -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Height (cm)"
                        app:boxBackgroundColor="@color/white"
                        app:boxCornerRadiusBottomEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxStrokeColor="@color/border_strong"
                        app:hintTextColor="@color/ink_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/profileHeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/ink_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Weight -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Weight (kg)"
                        app:boxBackgroundColor="@color/white"
                        app:boxCornerRadiusBottomEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxStrokeColor="@color/border_strong"
                        app:hintTextColor="@color/ink_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/profileWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/ink_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Thermal sensitivity -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thermal sensitivity"
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/profileThermal"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/rounded_card"
                        android:backgroundTint="@color/white"
                        android:paddingHorizontal="12dp" />

                    <!-- Style preference -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Style preference"
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/profileStyle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/rounded_card"
                        android:backgroundTint="@color/white"
                        android:paddingHorizontal="12dp" />

                    <!-- Skin tone -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Skin tone"
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/profileSkin"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/rounded_card"
                        android:backgroundTint="@color/white"
                        android:paddingHorizontal="12dp" />

                    <!-- Hair color -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hair color"
                        android:textColor="@color/ink_muted"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/profileHair"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/rounded_card"
                        android:backgroundTint="@color/white"
                        android:paddingHorizontal="12dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/profileSaveStyleBtn"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/brand_accent"
                    android:text="Save changes"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
